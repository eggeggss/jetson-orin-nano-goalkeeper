# ── OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# ── Camera ───────────────────────────────────────────────
CAMERA_INDEX=0                    # /dev/video0 → 0, /dev/video1 → 1

# ── Face recognition ─────────────────────────────────────
FACE_CONFIDENCE_THRESHOLD=0.45    # cosine similarity threshold (0~1)
FACE_DETECTION_INTERVAL_MS=500    # check every N ms (10fps = 100ms)

# ── Audio (run `make audio-devices` to list available IDs) ─
AUDIO_INPUT_DEVICE=-1             # -1 = system default mic
AUDIO_OUTPUT_DEVICE=-1            # -1 = system default speaker

# ── Conversation ─────────────────────────────────────────
CONVERSATION_MAX_SECONDS=120      # max conversation length
COOLDOWN_SECONDS=30               # same person cooldown after event

# ── Data retention ───────────────────────────────────────
RETENTION_DAYS=30

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=INFO
